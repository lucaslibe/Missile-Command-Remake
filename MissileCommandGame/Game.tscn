[sub_resource type="GDScript" id="GDScript_xwkxq"]
script/source = "extends Area2D
@onready var label1 = $controledisplay/payloadHas
@onready var label2 = $controledisplay/payloadCost
@onready var label3 = $controledisplay/fuelHas
@onready var label4 = $controledisplay/fuelCost

func _ready():
	connect(\"mouse_entered\", Callable(self, \"_on_mouse_entered\"))
	connect(\"mouse_exited\", Callable(self, \"_on_mouse_exited\"))
	$\"visual\".self_modulate.a = 0.5
func _process(_delta: float) -> void:
	label1.text = str(EconomyHandler.Current_resources_gunpowder)
	label2.text = str(EconomyHandler.gunpowder_cost)
	label3.text = str(EconomyHandler.Current_resources_fuel)
	label4.text = str(EconomyHandler.fuel_cost)
	pass
func _on_mouse_entered() -> void:
	$\"visual\".self_modulate.a = 1

func _on_mouse_exited() -> void:
	$\"visual\".self_modulate.a = 0.5
"

