[sub_resource type="GDScript" id="GDScript_pbwgg"]
script/source = "extends Area2D
var HP
var cooldown
var resource = 1
var display
@onready var _animated_sprite = $visual
func _on_level_up():
	match HP:
		2:
			updateAnim()
		1:
			Globallevelup.deadcities -= 1
			HP = 2
			updateAnim()
		0:
			HP = 1
			updateAnim()
func _ready() -> void:
	Globallevelup.connect(\"level_up\", Callable(self, \"_on_level_up\"))
	$typeofresource.play(\"Empty\")
	connect(\"area_entered\", Callable(self, \"_on_area_entered\"))
	HP = 2
	Globallevelup.deadcities = 0
	updateAnim()
	cooldown = 3
	resource = 1
func updateAnim() -> void:
	if HP == 2:
		_animated_sprite.play(\"standby\")
	if HP == 1:
		_animated_sprite.play(\"repairing\")
	if HP == 0:
		_animated_sprite.play(\"destroyed\")
func _process(delta: float) -> void:
	if display == true:
		if resource == 1 and HP == 2:
			$typeofresource.play(\"Fuel\")
		if resource == 2 and HP == 2:
			$typeofresource.play(\"Payload\")
	else:
		$typeofresource.play(\"Empty\")
	if cooldown > 0:
		cooldown -= 1 *delta
	if cooldown <= 0:
		if resource == 1 and HP == 2:
			EconomyHandler.Current_resources_fuel += 1
			_animated_sprite.play(\"fuel\")
			cooldown = 2
		if resource == 2 and HP == 2:
			EconomyHandler.Current_resources_gunpowder += 1
			_animated_sprite.play(\"payload\")
			cooldown = 2
func _on_area_entered(area):
	if area.is_in_group(\"ExplosionEnemy\"):
		if HP == 2:
			Globallevelup.deadcities += 1
			_animated_sprite.play(\"damaged\")
			HP = 0
		if HP == 1:
			HP = 0
			updateAnim()
func _on_input_event(_viewport: Node, event: InputEvent, _shape_idx: int) -> void:
	if event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_LEFT:
		match resource:
			1:
				resource = 2
			2:
				resource = 1
	pass
func _on_mouse_entered() -> void:
	display = true

func _on_mouse_exited() -> void:
	display = false
"

