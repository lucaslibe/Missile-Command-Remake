[sub_resource type="GDScript" id="GDScript_68r7h"]
script/source = "extends AnimatedSprite2D
var level = 1
@onready var _animated_sprite = $\".\"
func _ready() -> void:
	Globallevelup.connect(\"level_up\", Callable(self, \"_on_level_up\"))
	level = 1
func _on_level_up():
	level += 1
func _process(_delta: float) -> void:
	match level:
		1:
			_animated_sprite.play(\"level1\")
		2:
			_animated_sprite.play(\"level2\")
		3:
			_animated_sprite.play(\"level3\")
		4:
			_animated_sprite.play(\"level4\")
"

[sub_resource type="GDScript" id="GDScript_7vltt"]
resource_name = "fade"
script/source = "extends CanvasLayer
@onready var rect := $ColorRect

func fade_in(time := 0.5):
	rect.modulate.a = 1.0
	var t = create_tween()
	t.tween_property(rect, \"modulate:a\", 0.0, time * 2)

func fade_out(time := 0.5):
	rect.modulate.a = 0.0
	var t = create_tween()
	t.tween_property(rect, \"modulate:a\", 1.0, time)
"

